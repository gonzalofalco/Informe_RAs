TELECENTRO_USER=
TELECENTRO_PASS=
CRM_USER=
CRM_PASS=
CRM_URL=http://crm.telecentro.local//MembersLogin.aspx
CRM_RECLAMO_URL=http://crm.telecentro.local//Cliente/ReclamoAdministrativo/ReclamoCierre.aspx?SubMenu=475
# Una o varias clasificaciones separadas por | o coma.
# Ejemplo: CNOC - BANDA ANCHA|CNOC - INTERNET|OTRA CLASIFICACION
TELECENTRO_CLASIFICACIONES="CNOC - BANDA ANCHA|CNOC - FTTH|CNOC - HFC|CNOC - MESH|CNOC - TELEF RESID|CNOC - TELEVISION"
CRM_FORCE_HOST_MAP=auto
CRMWEB_HOST=crmweb.telecentro.local
APICRM_HOST=apicrm.telecentro.local
CRMREP_HOST=crmrep.telecentro.local
CRM_INTERNAL_HOST=crm.telecentro.local
# IP interna REAL de crmweb (no necesariamente la de crm.telecentro.local)
CRMWEB_TARGET_IP=
# IP interna REAL de apicrm (si no se define, usa CRMWEB_TARGET_IP)
APICRM_TARGET_IP=
# IP interna REAL de crmrep (si no se define, usa CRMWEB_TARGET_IP)
CRMREP_TARGET_IP=10.190.12.90

# Timeouts (milisegundos) para entornos lentos
TELECENTRO_UI_TIMEOUT_MS=15000
TELECENTRO_RECLAMO_WAIT_MS=45000
TELECENTRO_DOWNLOAD_TIMEOUT_MS=60000
# Ventana de fechas: desde N dias atras hasta hoy.
TELECENTRO_LOOKBACK_DAYS=7

# Postproceso: divide los CSV filtrados por keyword en dos ventanas horarias.
# Defaults:
# - Window1: dia anterior 15:30 -> dia actual 08:30
# - Window2: dia actual 08:30 -> dia actual 15:30
# Opcional: podes fijar fechas explicitas con *_START_DATE / *_END_DATE.
RAS_WINDOW1_START_DATE=
RAS_WINDOW1_END_DATE=
RAS_WINDOW1_START=15:30
RAS_WINDOW1_END=08:30
RAS_WINDOW2_START_DATE=
RAS_WINDOW2_END_DATE=
RAS_WINDOW2_START=08:30
RAS_WINDOW2_END=15:30
# Campo temporal para dividir ventanas: comment (ULTIMA FECHA COMENTARIO) o creation (FECHA DE CREACION)
RAS_SPLIT_TIME_FIELD=comment
RAS_SPLIT_OUTPUT_DIR=downloads/divididos
